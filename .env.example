# Supabase — dedicated project for MyAITwin
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase Management API — used by scripts/run-migration.mjs
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=your-project-ref

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=myaitwin

# OpenAI — embeddings, auto-tagging, voice-note extraction, Whisper transcription
OPENAI_API_KEY=sk-...

# Anthropic — required for the web mini-interface (/twin):
# powers POST /api/twin/chat and /api/twin/synthesise via Claude Sonnet 4.6.
ANTHROPIC_API_KEY=sk-ant-...

# Resend — for magic link emails
RESEND_API_KEY=re_...
RESEND_FROM=team@lutolearn.com

# JWT secret — required, generate with: openssl rand -base64 32
JWT_SECRET=

# App URL — used in magic link emails and as the base for MCP URLs
APP_URL=https://myaitwin.lutolearn.com

# OAuth — access token lifetime for tokens issued via /api/oauth/token.
# Refresh tokens (when offline_access scope is granted) are hardcoded to 30 days.
# Legacy URL-paste tokens never expire (unchanged behaviour).
OAUTH_TOKEN_EXPIRY_SECONDS=86400

# Admin auth — protects /api/admin/* endpoints
# ADMIN_TOKEN gates seeding, backfills, and the cross-tenant test suite.
# ADMIN_DASHBOARD_PASSWORD gates the cohort dashboard and mint-test-token.
ADMIN_TOKEN=
ADMIN_DASHBOARD_PASSWORD=

# Default system prompt loaded by lib/system-prompt.js. Multi-line value.
# In dev: paste the markdown content. In production: set via Vercel UI.
MYAITWIN_SYSTEM_PROMPT=
